# Keep the build context small — everything below is either generated,
# secret, or platform-specific and should NOT be baked into the image.

# Version control
.git
.gitignore
.gh_token

# Local secrets / state
.env
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Python build/test artefacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
backend/venv/
venv/
.venv/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Docs that bloat the image
docs/
README.md
PRD.md
progress.md
tests/

# Misc tooling
.claude/
.playwright-mcp/

# Build outputs
dist/
build/
node_modules/

# Container files themselves
Dockerfile*
docker-compose*.yml
.dockerignore
