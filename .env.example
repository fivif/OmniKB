# ── HuggingFace ────────────────────────────────────────────────
# HF_ENDPOINT=https://hf-mirror.com

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=omnikb
# qdrant_mode: local(默认,无需安装服务) | remote(独立Qdrant服务) | memory(内存临时)
QDRANT_MODE=local
QDRANT_LOCAL_PATH=./data/qdrant

# ── LLM — 第三方 OpenAI 兼容接口 ─────────────────────────────
# Provider: custom | openai | anthropic | ollama
LLM_PROVIDER=custom
LLM_MODEL=deepseek-v4-pro
# 填写你的第三方 API Base URL，例如：
#   SiliconFlow: https://api.siliconflow.cn/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   其他 OpenAI 兼容服务同理
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXX

# 如需直接使用官方 OpenAI / Anthropic，填写以下密钥
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding — 硅基流动 BGE-M3 ──────────────────────────────
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
# 硅基流动 API Key（与 LLM_API_KEY 可以相同）
SILICONFLOW_API_KEY=sk-hysrktzmskumahrghtkncyatvjjbnflrwckbwwlcihnatpyu
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── MCP Server ────────────────────────────────────────────────
# Replace with a strong random secret before exposing externally
MCP_API_KEY=changeme-replace-with-strong-secret

# ── Storage ───────────────────────────────────────────────────
DATA_DIR=./data
SQLITE_PATH=./data/omnikb.db

# tensorflow 2.16.x 与 numpy 2.x ABI 不兼容，跳过 TF/JAX 后端
USE_TF=0
USE_JAX=0

WEB_JUDGE_ENABLED=true
WEB_JUDGE_MIN_SCORE=4

# ── P1 高级功能 ───────────────────────────────────────────────
# Whisper 模型大小 (tiny/base/small/medium/large-v2)，需安装 faster-whisper
WHISPER_MODEL_SIZE=base
# 重排序（CrossEncoder）；需安装 sentence-transformers
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 摄入时自动标签（调用 LLM）
AUTOTAG_ENABLED=true
# ── Vision 多模态视觉 ─────────────────────────────────────────
# 开启 vision（PDF OCR、DOCX 图片识别、视频帧描述）
VISION_ENABLED=true
VISION_PROVIDER=custom
VISION_MODEL=qwen3.5-omni-flash
# Vision 独立 API Key（留空则复用对应 provider 的主 key）
VISION_API_KEY=XXXXXXXXXX
# Vision 独立 Base URL（留空则复用对应 provider 的主 base_url）
VISION_BASE_URL=XXXXXXXXXXXXXXXX
# 视频每隔多少秒抽一帧描述（0=禁用）
VISION_FRAME_INTERVAL=60
# PDF 每页字符数低于此值时触发 OCR
VISION_PDF_OCR_THRESHOLD=80

# ── Network proxy ──────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:10808

# ── Web Agent 预算（1M 上下文模型）────────────────────────
WEB_AGENT_MAX_INPUT_TOKENS=800000
WEB_AGENT_MAX_SECONDS=1200
# 工具调用不设上限，每 N 次注入反思检查点
WEB_AGENT_MAX_TOOL_CALLS=0
WEB_AGENT_REFLECTION_INTERVAL=8
