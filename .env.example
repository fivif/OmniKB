# ── OmniKB Configuration ────────────────────────────────────────
# Copy this to .env and fill in your values.

# ── LLM — DeepSeek / OpenAI 兼容接口 ─────────────────────────
# Provider: deepseek | custom
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com/v1
# Key 在 Web UI 设置面板中填入，或直接写在这里
# LLM_API_KEY=sk-xxx

# ── MCP Server ────────────────────────────────────────────────
MCP_API_KEY=changeme-replace-with-strong-secret

# ── Storage ───────────────────────────────────────────────────
DATA_DIR=backend/data
SQLITE_PATH=backend/data/omnikb.db

# ── Qdrant (local mode, no external service needed) ──────────
QDRANT_MODE=local
QDRANT_LOCAL_PATH=./data/qdrant

# ── Vision 多模态视觉 (PDF OCR / 视频帧描述) ────────────────
VISION_ENABLED=false
VISION_MODEL=gpt-4o-mini

# ── Network proxy ──────────────────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890

# ── Web Agent — 0=unlimited, uses model context + auto-compaction ──
WEB_AGENT_REFLECTION_INTERVAL=8

# ── Admin panel password (empty = no auth, everyone can access) ──
# ADMIN_PASSWORD=xxx

# ── Wiki ──────────────────────────────────────────────────
WIKI_ENABLED=true
WIKI_RETRIEVAL_ENABLED=true
WIKI_MAX_SOURCE_CHARS=8000
