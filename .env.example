# ── Qdrant ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=omnikb
# qdrant_mode: local(默认,无需安装服务) | remote(独立Qdrant服务) | memory(内存临时)
QDRANT_MODE=local
QDRANT_LOCAL_PATH=./data/qdrant

# ── LLM — 第三方 OpenAI 兼容接口 ─────────────────────────────
# Provider: custom | openai | anthropic | ollama
LLM_PROVIDER=custom
LLM_MODEL=deepseek-v4-pro
# 填写你的第三方 API Base URL，例如：
#   SiliconFlow: https://api.siliconflow.cn/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   其他 OpenAI 兼容服务同理
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
# 兼容 thinking 模式的可选 extra_body（JSON 对象字符串）
# DeepSeek-Reasoner / 其他原生 thinking 模型：留空即可（运行时自动剥离 reasoning_content）
# Qwen3 / SiliconFlow 混合模型显式关闭 thinking：
#   LLM_EXTRA_BODY={"enable_thinking": false}
LLM_EXTRA_BODY=

# 如需直接使用官方 OpenAI / Anthropic，填写以下密钥
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# 开启 vision
VISION_ENABLED=true

# Provider（空 = 继承 LLM_PROVIDER）: custom | openai | anthropic
VISION_PROVIDER=custom
VISION_MODEL=qwen3.5-omni-flash 

# Vision 独立 API Key（留空则复用对应 provider 的主 key）
VISION_API_KEY=

# Vision 独立 Base URL（留空则复用对应 provider 的主 base_url）
# 例：https://api.siliconflow.cn/v1 (SiliconFlow VL 模型)
#     https://api.openai.com/v1     (官方 OpenAI)
VISION_BASE_URL=

# 视频每隔多少秒取一帧描述（0 = 不描述帧）
VISION_FRAME_INTERVAL=60

# PDF 每页文字少于多少字才触发 OCR
VISION_PDF_OCR_THRESHOLD=80


# ── Embedding — 硅基流动 BGE-M3 ──────────────────────────────
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
# 硅基流动 API Key（与 LLM_API_KEY 可以相同）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── MCP Server ────────────────────────────────────────────────
# Replace with a strong random secret before exposing externally
MCP_API_KEY=changeme-replace-with-strong-secret

# ── Storage ───────────────────────────────────────────────────
DATA_DIR=./data
SQLITE_PATH=./data/omnikb.db

# ── P1 高级功能 ───────────────────────────────────────────────
# Whisper 模型大小 (tiny/base/small/medium/large-v2)，需安装 faster-whisper
WHISPER_MODEL_SIZE=base
# 重排序（CrossEncoder）；需安装 sentence-transformers
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 摄入时自动标签（调用 LLM）
AUTOTAG_ENABLED=false

# ── 兼容性修复 ────────────────────────────────────────────────
# tensorflow 2.16.x 与 numpy 2.x 存在 ABI 不兼容，
# 设置以下变量让 HuggingFace transformers 跳过 TF 后端，服务器正常启动。
USE_TF=0
USE_JAX=0

# — LLM 对单页评分 0-10，返回 keep/score/reason/summary。低于阈值直接丢弃，不入库。
# score_links(links, base_url, intent) — 整站爬取时，LLM 从候选链接里筛出与意图相关的，其余不跟进，彻底避免无意义的 BFS 扩散。

WEB_JUDGE_ENABLED=true
WEB_JUDGE_MIN_SCORE=4

# ── Web Agent 连接池（P0）──────────────────────────────────────
# jshookmcp 持久连接数（每个 = 一个 npx 子进程）
JSHOOK_POOL_SIZE=2
# Playwright 浏览器实例数（每个 = 一个 Chromium 进程）。0 = 禁用
PLAYWRIGHT_POOL_SIZE=1
